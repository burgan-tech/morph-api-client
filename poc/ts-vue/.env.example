# Vite merges VITE_* from ../.env first; non-empty values here override (see vite.config.ts).

# --- Keycloak ---
# Dev: token requests use Vite proxy /__keycloak → localhost:8080 (fixes browser CORS).
# Override only if Keycloak is on a different host/port:
# VITE_KEYCLOAK_ORIGIN=http://localhost:8080

# --- Client secrets (must match Keycloak realm) ---
VITE_DEVICE_CLIENT_SECRET=morph-device-secret
VITE_LOGIN_CLIENT_SECRET=morph-login-secret
VITE_SESSION_CLIENT_SECRET=morph-session-secret

# --- OAuth redirect ---
# All providers share /oauth/callback. Dev: origin auto-detected from the tab.
# Prod: set the full callback URL if the app is behind a custom domain:
# VITE_OAUTH_REDIRECT_URI=https://your-host/oauth/callback

# --- Device / installation ids ---
# Leave unset for web simulation (auto-generated UUIDs in localStorage/sessionStorage).
# Pin for fixed demos/CI:
# VITE_DEVICE_ID=poc-device
# VITE_INSTALLATION_ID=poc-install

# --- Google OAuth (optional) ---
# Without both ID + secret, Google buttons stay disabled.
# Authorized redirect URI: http://localhost:5173/oauth/callback
# See docs/poc/google-setup.md
# VITE_GOOGLE_CLIENT_ID=....apps.googleusercontent.com
# VITE_GOOGLE_CLIENT_SECRET=GOCSPX-...

# --- Simulation ---
# VITE_SIMULATION_MODE=true
# VITE_MOCK_API_BASE=http://localhost:3000
